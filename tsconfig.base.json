{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "incremental": true,
    "composite": true,
    "tsBuildInfoFile": "${configDir}/.tsbuildinfo",
    "baseUrl": "${configDir}",
    "paths": {
      "@forge/types": ["packages/types/src"],
      "@forge/ui": ["packages/ui/src"],
      "@forge/sdk": ["packages/sdk/src"],
      "@forge/auth-engine": ["packages/auth-engine/src"],
      "@forge/database-engine": ["packages/database-engine/src"],
      "@forge/storage-engine": ["packages/storage-engine/src"],
      "@forge/storage-types": ["packages/storage-types/src"],
      "@forge/storage-client": ["packages/storage-client/src"],
      "@forge/connector-core": ["packages/connector-core/src"],
      "@forge/connector-runtime": ["packages/connector-runtime/src"],
      "@forge/connector-registry": ["packages/connector-registry/src"],
      "@forge/connector-marketplace": ["packages/connector-marketplace/src"],
      "@forge/connector-sdk": ["packages/connector-sdk/src"],
      "@forge/custom-connector": ["packages/custom-connector/src"],
      "@forge/payment-types": ["packages/payment-types/src"],
      "@forge/payment-engine": ["packages/payment-engine/src"],
      "@forge/blockchain-types": ["packages/blockchain-types/src"],
      "@forge/blockchain-engine": ["packages/blockchain-engine/src"],
      "@forge/ai-types": ["packages/ai-types/src"],
      "@forge/ai-engine": ["packages/ai-engine/src"],
      "@forge/component-types": ["packages/component-types/src"],
      "@forge/component-engine": ["packages/component-engine/src"],
      "@forge/marketplace-types": ["packages/marketplace-types/src"],
      "@forge/marketplace-engine": ["packages/marketplace-engine/src"],
      "@forge/deployment-types": ["packages/deployment-types/src"],
      "@forge/deployment-engine": ["packages/deployment-engine/src"],
      "@forge/enterprise-types": ["packages/enterprise-types/src"],
      "@forge/enterprise-engine": ["packages/enterprise-engine/src"],
      "@forge/config-types": ["packages/config-types/src"],
      "@forge/config-engine": ["packages/config-engine/src"],
      "@forge/config-client": ["packages/config-client/src"],
      "@forge/data-types": ["packages/data-types/src"],
      "@forge/data-engine": ["packages/data-engine/src"],
      "@forge/identity-types": ["packages/identity-types/src"],
      "@forge/identity-engine": ["packages/identity-engine/src"],
      "@forge/identity-client": ["packages/identity-client/src"],
      "@forge/reactive-types": ["packages/reactive-types/src"],
      "@forge/reactive-engine": ["packages/reactive-engine/src"],
      "@forge/reactive-client": ["packages/reactive-client/src"],
      "@forge/resource-types": ["packages/resource-types/src"],
      "@forge/resource-engine": ["packages/resource-engine/src"],
      "@forge/workflow-types": ["packages/workflow-types/src"],
      "@forge/workflow-engine": ["packages/workflow-engine/src"],
      "@forge/secret-manager": ["packages/secret-manager/src"],
      "@forge/forge-components": ["packages/forge-components/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "build"]
}
