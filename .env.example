# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://forge:forge_secret@localhost:5432/forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge_secret
POSTGRES_DB=forge

# ─── Cache (Redis) ────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication (JWT) ─────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=forge
JWT_AUDIENCE=forge-client

# ─── Storage ──────────────────────────────────────
STORAGE_PROVIDER=s3
STORAGE_BUCKET=forge-storage
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_MAX_FILE_SIZE=10485760

# ─── Dashboard (Next.js) ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Rate Limiting ────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Logging ──────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ─── Connector Engine ────────────────────────────
CONNECTORS_DIR=./connectors
SECRET_ENCRYPTION_KEY=change-this-to-a-32-byte-hex-secret-key
MARKETPLACE_API_URL=http://localhost:4000/marketplace

# ─── Workflow Engine ────────────────────────────
WORKFLOW_MAX_EXECUTION_TIMEOUT=300000
WORKFLOW_MAX_LOOP_ITERATIONS=100
