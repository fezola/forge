{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Forge — A production-grade Backend-as-a-Service platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "turbo run db:migrate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  },
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=20.18.0"
  }
}
