    "@forge/workflow-types": "workspace:*",
    "@forge/types": "workspace:*",
    "@forge/reactive-engine": "workspace:*",
    "@forge/reactive-types": "workspace:*",
    "@forge/reactive-client": "workspace:*",
    "@forge/payment-types": "workspace:*",
    "@forge/payment-engine": "workspace:*",
    "@forge/blockchain-types": "workspace:*",
