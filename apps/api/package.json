    "@nestjs/throttler": "^6.3.0",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/config": "^3.3.0",
    "@prisma/client": "^6.0.1",
    "@forge/auth-engine": "workspace:*",
    "@forge/database-engine": "workspace:*",
    "@forge/storage-engine": "workspace:*",
    "@forge/connector-core": "workspace:*",
    "@forge/connector-sdk": "workspace:*",
    "@forge/connector-runtime": "workspace:*",
    "@forge/connector-registry": "workspace:*",
    "@forge/connector-marketplace": "workspace:*",
