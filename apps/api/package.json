    "@forge/ai-types": "workspace:*",
    "@forge/ai-engine": "workspace:*",
    "@forge/component-types": "workspace:*",
    "@forge/component-engine": "workspace:*",
    "@forge/marketplace-types": "workspace:*",
    "@forge/marketplace-engine": "workspace:*",
    "@forge/deployment-types": "workspace:*",
    "@forge/deployment-engine": "workspace:*",
